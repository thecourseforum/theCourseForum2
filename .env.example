# EC2_USER=
# PEM_KEY=path/to/your/key.pem
# PROD_DB_HOST=
# PROD_DB_USER=
# PROD_DB_PASSWORD=

# =============================================================================
# OPTIONAL - For generate_ai_summaries management command
# =============================================================================
# OPENROUTER_API_KEY=

# =============================================================================
# OPTIONAL - For aws configure
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# OPTIONAL - For Sentry error tracking and performance monitoring
# =============================================================================
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=1.0  # 100% of requests for performance monitoring (lower in prod if needed)
# SENTRY_PROFILES_SAMPLE_RATE=1.0  # 100% of requests for profiling (lower in prod if needed)

# =============================================================================
# OPTIONAL - For load_review_drive management command
# =============================================================================
# REVIEW_DRIVE_ID=
# REVIEW_DRIVE_EMAIL=
# REVIEW_DRIVE_PASSWORD=